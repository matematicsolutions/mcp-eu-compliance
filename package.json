{
  "name": "@matematicsolutions/mcp-eu-compliance",
  "version": "0.2.2",
  "description": "MCP server - offline EU compliance corpus (EUR-Lex full text via local SQLite FTS5, verbatim zero-LLM) for GDPR, AI Act, DORA, NIS2, eIDAS 2.0, CRA",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "fetch-corpus": "node scripts/fetch-corpus.mjs",
    "smoke": "node test/smoke.mjs",
    "drift": "node test/drift.mjs"
  },
  "keywords": [
    "mcp",
    "eu",
    "compliance",
    "eur-lex",
    "gdpr",
    "ai-act",
    "dora",
    "nis2",
    "eidas",
    "cra",
    "legal"
  ],
  "author": "MateMatic / Wieslaw Mazur",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.19.3",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "mcpName": "io.github.matematicsolutions/mcp-eu-compliance",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matematicsolutions/mcp-eu-compliance.git"
  },
  "bin": {
    "mcp-eu-compliance": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
